# ============================================
# MentWel Frontend - Example env file
# Copy to .env for local development.
# In production, set these in your hosting provider's dashboard.
# ============================================

# ---- LOCAL DEVELOPMENT (defaults) ----
VITE_API_URL=http://localhost:5000/api/v1
VITE_BACKEND_URL=http://localhost:5000
VITE_APP_URL=http://localhost:3000

# ---- PRODUCTION EXAMPLES (replace with your real URLs) ----
# VITE_API_URL=https://your-backend.onrender.com/api/v1
# VITE_BACKEND_URL=https://your-backend.onrender.com
# VITE_APP_URL=https://your-frontend.netlify.app

# App
VITE_APP_NAME=MentWel

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CHAT=true

# Clerk Authentication (get key from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# OpenRouter API key for the ChatBot (https://openrouter.ai)
VITE_OPENROUTER_API_KEY=sk-or-v1-your_key_here
